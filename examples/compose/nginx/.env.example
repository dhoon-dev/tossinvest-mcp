# Copy this file to .env before running the Nginx compose example.
# All values are intentionally empty. Fill only the values for your deployment.

## Required

# Docker secret file paths. Generate these from your host secret manager.
TOSSINVEST_CLIENT_ID_FILE=
TOSSINVEST_CLIENT_SECRET_FILE=

# TossInvest account selection. Set exactly one of these values.
TOSSINVEST_ACCOUNT_NO=
TOSSINVEST_ACCOUNT_SEQ=

# OAuth resource-server settings from your authorization server.
TOSSINVEST_MCP_OAUTH_ISSUER_URL=
TOSSINVEST_MCP_OAUTH_RESOURCE_URL=
TOSSINVEST_MCP_OAUTH_JWKS_URI=

# Set at least one personal allowlist value for public deployments.
TOSSINVEST_MCP_OAUTH_ALLOWED_SUBJECTS=
TOSSINVEST_MCP_OAUTH_ALLOWED_EMAILS=

# CIDR for the trusted Nginx network that reaches the app container.
TOSSINVEST_MCP_TRUSTED_PROXY_CIDR=

## Optional

# Defaults to tossinvest-mcp-remote:latest.
TOSSINVEST_MCP_IMAGE=

# Defaults to the repository root when running this example compose file.
TOSSINVEST_MCP_BUILD_CONTEXT=

# Defaults to tossinvest:read in the compose file.
TOSSINVEST_MCP_OAUTH_REQUIRED_SCOPES=

# Defaults to RS256 in the compose file.
TOSSINVEST_MCP_OAUTH_ALGORITHMS=

# Optional audience override. Leave empty to rely on the resource URL.
TOSSINVEST_MCP_OAUTH_AUDIENCES=

# Defaults to nginx:stable-alpine.
NGINX_IMAGE=

# Defaults to 127.0.0.1 so the example is not publicly exposed by accident.
NGINX_BIND_ADDRESS=

# Defaults to 8080.
NGINX_HTTP_PORT=
